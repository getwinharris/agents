---
import { docsHref, type DocsSection } from '../../lib/docs-navigation';

interface Props {
	section: DocsSection;
	active: boolean;
	mobile?: boolean;
	baseUrl?: string;
}

const { section, active, mobile = false, baseUrl } = Astro.props;
const href = baseUrl
	? new URL(`${section.landingSlug}${section.landingSlug ? '/' : ''}`, baseUrl).href
	: docsHref(section.landingSlug);
---

<a
	class:list={[
		mobile ? 'text-sm font-medium' : 'relative flex h-full items-center gap-2 hover:text-[var(--docs-accent-deep)]',
		active ? 'text-[var(--docs-accent-deep)]' : 'text-[var(--docs-muted)]',
		{ 'after:absolute after:right-0 after:-bottom-px after:left-0 after:h-0.5 after:bg-[var(--docs-accent-deep)] after:content-[\'\']': active && !mobile },
	]}
	href={href}
>
	{section.title}
</a>
