---
interface Props {
	depth: number;
	slug: string;
	text: string;
}

const { depth, slug, text } = Astro.props;
---

<li class:list={['[&+&]:mt-2.5 leading-none', { 'pl-3.5': depth === 3 }]}>
	<a class="block text-sm text-[var(--docs-muted)] hover:text-[var(--ink)]" href={`#${slug}`}>{text}</a>
</li>
