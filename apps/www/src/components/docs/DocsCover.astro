---
interface Props {
	variant: 'agents' | 'workflows';
}

const { variant } = Astro.props;
const config = variant === 'agents'
	? { shape: 'swirl', scale: '0.25', patternId: 'agentsCoverGrid' }
	: { shape: 'sphere', scale: '1.02', patternId: 'workflowsCoverGrid' };
---

<div class="relative mb-8 flex h-[200px] items-center justify-center overflow-hidden rounded-sm border border-[var(--docs-border)] bg-[var(--docs-surface-soft)] max-docs-desktop:mb-6 max-docs-desktop:h-[168px]" aria-hidden="true">
	<svg class="absolute inset-0 size-full">
		<defs>
			<pattern id={config.patternId} width="20" height="20" patternUnits="userSpaceOnUse">
				<path d="M20 0H0V20" fill="none" stroke="#8851d9" stroke-opacity="0.62" stroke-width="0.8" stroke-dasharray="1 2" />
			</pattern>
		</defs>
		<rect width="100%" height="100%" fill={`url(#${config.patternId})`} />
	</svg>
	<div
		class="docs-cover-shader relative z-10 size-[144px] rounded-full max-docs-desktop:size-[128px]"
		style="--shadow-rgb: 136 81 217;"
		data-docs-cover-shader
		data-color-back="#00000000"
		data-color-front="#8851d9"
		data-shape={config.shape}
		data-type="4x4"
		data-size="2"
		data-scale={config.scale}
		data-speed="0.18"
	></div>
</div>

<script>
	import { setupDocsCoverShaders } from '../../docs-cover-shaders';

	setupDocsCoverShaders();
</script>
