---
import { getCollection } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import { blogsSection } from '../../lib/blogs-navigation';

const posts = (await getCollection('blogs')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<DocsLayout
	title="Blogs"
	description="Announcements, releases, research, and tutorials from bapX."
	currentSlug=""
	headings={[]}
	showTableOfContents={false}
	variant="directory"
	navigationSection={blogsSection}
	headerSections={[blogsSection]}
	publicBaseUrl="https://blogs.bapx.in/"
	markdownUrl=""
>
	<header class="mb-10">
		<h1 class="m-0 text-5xl font-bold leading-[1.08] tracking-[-0.05em] text-gray-950">Blogs</h1>
		<p class="mt-4 text-base leading-7 text-gray-600">Announcements, releases, research, and tutorials from the bapX team.</p>
	</header>
	<ul class="m-0 list-none p-0" role="list">
		{posts.map((post) => (
			<li class="border-t border-[var(--hairline)] py-6">
				<p class="m-0 text-sm text-[var(--docs-muted)]">{post.data.category} · {post.data.pubDate.toLocaleDateString('en-US', { dateStyle: 'long', timeZone: 'UTC' })}</p>
				<h2 class="mt-2 text-2xl font-semibold"><a href={`/${post.id}/`}>{post.data.title}</a></h2>
				{post.data.description && <p class="mt-2 text-base text-[var(--docs-muted)]">{post.data.description}</p>}
			</li>
		))}
	</ul>
</DocsLayout>
