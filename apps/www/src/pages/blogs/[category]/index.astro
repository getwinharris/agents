---
import { getCollection } from 'astro:content';
import DocsLayout from '../../../layouts/DocsLayout.astro';
import { blogsSection } from '../../../lib/blogs-navigation';

export function getStaticPaths() {
	const categories = ['announcement', 'release', 'research', 'tutorials'] as const;
	return categories.map((category) => ({ params: { category }, props: { category } }));
}
const { category } = Astro.props;
const posts = (await getCollection('blogs')).filter((post) => post.data.category === category).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const title = category === 'tutorials' ? 'Tutorials' : `${category[0].toUpperCase()}${category.slice(1)}s`;
---

<DocsLayout title={title} description={`bapX ${title.toLowerCase()}.`} currentSlug={category} headings={[]} showTableOfContents={false} variant="directory" navigationSection={blogsSection} headerSections={[blogsSection]} publicBaseUrl="https://blogs.bapx.in/" markdownUrl="">
	<header class="blog-directory-header"><h1 class="blog-directory-title">{title}</h1></header>
	{posts.length === 0 ? <p>No posts published yet.</p> : <ul class="m-0 list-none p-0" role="list">{posts.map((post) => <li class="border-t border-[var(--hairline)] py-6"><h2 class="text-2xl font-semibold"><a href={`/${post.id}/`}>{post.data.title}</a></h2><p class="mt-2 text-[var(--docs-muted)]">{post.data.description}</p></li>)}</ul>}
</DocsLayout>

<style>
	.blog-directory-header { margin-bottom: 2.5rem; }
	.blog-directory-title { margin: 0; color: var(--docs-text); font-size: 3rem; font-weight: 700; line-height: 1.08; letter-spacing: -0.05em; }
</style>
