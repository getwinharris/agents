---
import "../../../styles/global.css";

export function getStaticPaths() {
  const clients = [
    { slug: "gut-conference", name: "GUT Conference", category: "Web product", summary: "Web product development and management tailored for conference operations.", links: [{ label: "Website", href: "https://gutconference.online/" }] },
    { slug: "sri-panchami-spiritual", name: "Sri Panchami Spiritual", category: "Web product", summary: "Web product development and management tailored for a spiritual service brand.", links: [{ label: "Website", href: "https://sripanchamispiritual.com/" }] },
    { slug: "nebo-lifestyle-clinic", name: "NEBO Lifestyle Clinic", category: "Web and social", summary: "Full business conversion online funnel, website, and social media management.", links: [{ label: "Website", href: "https://nebowellness.com/" }, { label: "Instagram", href: "https://www.instagram.com/nebolifestyleclinic/" }, { label: "Facebook", href: "https://www.facebook.com/nebolifestyleclinic" }, { label: "YouTube", href: "https://www.youtube.com/@nebolifestyleclinic" }] },
    { slug: "flexi-feet", name: "Flexi Feet", category: "Web and social", summary: "Website and social media management for business presence and customer acquisition.", links: [{ label: "Website", href: "https://flexifeet.net/" }, { label: "Instagram", href: "https://www.instagram.com/flexifeetmalaysia/" }, { label: "Facebook", href: "https://www.facebook.com/flexifeetmalaysia" }, { label: "YouTube", href: "https://www.youtube.com/@flexifeetmalaysia" }, { label: "TikTok", href: "https://www.tiktok.com/@flexifeetmalaysia" }] },
    { slug: "indian-bariatrics", name: "Indian Bariatrics", category: "Web and social", summary: "Website and social media management for healthcare education and patient reach.", links: [{ label: "Website", href: "https://indianbariatrics.com/" }, { label: "Facebook", href: "https://www.facebook.com/FightObesityAndDiabetes/" }, { label: "YouTube", href: "https://www.youtube.com/@Bariatricdoctor" }, { label: "Instagram", href: "https://www.instagram.com/bariatric_doctor/" }] },
    { slug: "happy-feet-erode", name: "Happy Feet Erode", category: "Social only", summary: "Social media content and management without a website build.", links: [{ label: "Instagram", href: "https://www.instagram.com/happyfeeterode/" }, { label: "Facebook", href: "https://www.facebook.com/happyfeeterode/" }, { label: "YouTube", href: "https://www.youtube.com/@happyfeeterode" }] },
  ];
  return clients.map((c) => ({ params: { client: c.slug }, props: c }));
}

const { name, category, summary, links } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{name} | bapX Media Hub</title>
    <meta name="description" content={summary} />
    <link rel="canonical" href={"https://mediahub.bapx.in/clients/" + Astro.params.client + "/"} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="sticky top-0 z-50 border-b border-[var(--hairline)] bg-[var(--canvas)]/80 backdrop-blur-sm">
      <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-6">
        <div class="flex h-full items-center gap-8">
          <a href="/" class="flex items-center gap-2">
            <img src="/brand/bapx-logo-main.svg" alt="bapX" class="h-7 w-auto" />
          </a>
          <div class="bapx-nav hidden lg:flex h-full items-center gap-7">
            <a href="/">Home</a>
            <a href="https://docs.bapx.in/getting-started/quickstart/">Docs</a>
            <a href="/mediahub/" class="active">Media Hub</a>
            <a href="https://blogs.bapx.in/">Blog</a>
            <a href="/products/">Products</a>
            <a href="/contact/">Contact</a>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <a href="https://agents.bapx.in/" class="bapx-pill">Agents</a>
          <a href="/login/" class="bapx-pill bapx-pill-primary">Sign in</a>
        </div>
      </div>
    </nav>

    <main class="page-section page-header" style="max-width: 800px; margin: 0 auto;">
      <a href="/mediahub/" class="bapx-pill" style="margin-bottom: 2rem;">&larr; Back to Media Hub</a>
      <span class="mono-label">{category}</span>
      <h1 class="display-xl" style="margin-top: .5rem;">{name}</h1>
      <p class="body-lg" style="margin-top: 1.5rem;">{summary}</p>

      <div style="margin-top: 3.375rem; border-top: 1px solid var(--hairline); padding-top: 2rem;">
        <h2 class="display-md">Links</h2>
        <div class="pill-links">
          {links.map((link) => (
            <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
          ))}
        </div>
      </div>
    </main>

    <footer class="page-footer">
      <div class="section-inner">
        <span>bapX Media Hub</span>
        <span>&copy; {new Date().getFullYear()}</span>
      </div>
    </footer>
  </body>
</html>
