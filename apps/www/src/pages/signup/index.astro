---
import '../../styles/global.css';
const networks=['Facebook','Instagram','TikTok','WeChat','LINE','Discord','Medium','Reddit','Pinterest','LinkedIn','YouTube','X'];
---
<!doctype html><html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><title>Create your bapX account</title><link rel="icon" type="image/svg+xml" href="/favicon.svg?v=bapx-20260711"/></head><body class="signup-page"><main class="signup-shell"><header><a href="https://bapx.in/"><img src="/brand/bapx-logo-main.svg" alt="bapX"/></a><span id="progress">1 / 4</span></header><form action="/api/auth/signup" method="post" id="signup-form">
<section class="step active"><p class="mono-label">ACCOUNT</p><h1>Who owns this workspace?</h1><label>Your name<input name="name" required/></label><label>Username<input name="username" pattern="[a-z0-9-]+" required/></label><label>Email<input type="email" name="email" required/></label><label>Password<input type="password" name="password" minlength="12" required/></label></section>
<section class="step"><p class="mono-label">BUSINESS</p><h1>Tell us about the business.</h1><label>Business name<input name="business_name" required/></label><label>Business workspace slug<input name="business_slug" pattern="[a-z0-9-]+" required/></label><label>Website <small>optional</small><input type="url" name="website" placeholder="https://"/></label></section>
<section class="step"><p class="mono-label">BUSINESS PAGES</p><h1>Select the social pages your business uses.</h1><p>These are business-page links, not personal profiles. Skip anything you do not use.</p><div class="networks">{networks.map((network)=><label class="network"><input type="checkbox" data-network={network.toLowerCase()}/><span>{network}</span></label>)}</div></section>
<section class="step"><p class="mono-label">SOCIAL LINKS</p><h1>Add only the selected business links.</h1><div id="social-fields"></div><p id="error" class="auth-error"></p><button class="bapx-pill bapx-pill-primary" type="submit">Create account and organisation</button></section>
<footer><button type="button" class="bapx-pill" id="back">Back</button><button type="button" class="bapx-pill bapx-pill-primary" id="next">Continue</button></footer></form></main>
<script is:inline>
const steps=[...document.querySelectorAll('.step')], next=document.querySelector('#next'), back=document.querySelector('#back');let current=0;
function show(){steps.forEach((s,i)=>s.classList.toggle('active',i===current));document.querySelector('#progress').textContent=`${current+1} / ${steps.length}`;back.hidden=current===0;next.hidden=current===steps.length-1;if(current===3){const box=document.querySelector('#social-fields');box.innerHTML='';document.querySelectorAll('[data-network]:checked').forEach(c=>{const n=c.dataset.network;box.insertAdjacentHTML('beforeend',`<label>${n[0].toUpperCase()+n.slice(1)} business page<input type="url" name="social_${n}" placeholder="https://"/></label>`);});if(!box.children.length)box.innerHTML='<p>No social pages selected. You can add them later.</p>';}}
next.onclick=()=>{const required=[...steps[current].querySelectorAll('[required]')];if(required.every(i=>i.reportValidity())){current++;show();}};back.onclick=()=>{current--;show();};document.querySelector('#error').textContent=new URLSearchParams(location.search).get('error')||'';show();
</script></body></html>
<style>
.signup-page{min-height:100vh;background:#0a0a0a;color:#fff}.signup-shell{width:min(820px,100%);margin:auto;padding:28px}.signup-shell header,.signup-shell footer{display:flex;justify-content:space-between;align-items:center}.signup-shell form{min-height:calc(100vh - 100px);display:flex;flex-direction:column}.step{display:none;flex:1;padding:8vh 0 32px}.step.active{display:block}.step h1{font-size:clamp(40px,7vw,72px);font-weight:400;letter-spacing:-.05em;line-height:1;margin:16px 0 38px}.step>label,#social-fields label{display:grid;gap:8px;margin:16px 0;max-width:600px;color:#dadbdf}.step input[type=text],.step input[type=email],.step input[type=password],.step input[type=url],.step input:not([type]){background:#191919;border:1px solid #363a3f;border-radius:8px;color:#fff;padding:14px;font:inherit}.networks{display:flex;flex-wrap:wrap;gap:12px}.network input{position:absolute;opacity:0}.network span{display:block;border:1px solid #363a3f;border-radius:999px;padding:10px 16px}.network input:checked+span{background:#fff;color:#0a0a0a}.auth-error{color:#ffb4a8}
.signup-shell header img{display:block;width:112px;height:auto}
</style>
