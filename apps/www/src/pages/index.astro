---
import "../styles/global.css";
import { Code } from "astro:components";
import { HERO, COPY_PROMPT } from "../code-snippets";
import { homepageEcosystemItems } from "../../../ecosystem-catalog";

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <title>bapX — Cloud Agent Automation for Teams</title>
    <meta name="description" content="Deploy AI agents that automate your business operations, team workflows, and customer operations — no infrastructure required." />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href="https://bapx.in/" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="bapX" />
    <meta property="og:title" content="bapX — Cloud Agent Automation for Teams" />
    <meta property="og:description" content="Deploy AI agents that automate your business operations, team workflows, and customer operations." />
    <meta property="og:url" content="https://bapx.in/" />
    <meta property="og:image" content="https://bapx.in/og3.jpg" />
    <meta property="og:image:alt" content="bapX logo" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="bapX — Cloud Agent Automation for Teams" />
    <meta name="twitter:description" content="Deploy AI agents that automate your business operations, team workflows, and customer operations." />
    <meta name="twitter:image" content="https://bapx.in/og3.jpg" />
    <meta name="twitter:image:alt" content="bapX logo" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="sticky top-0 z-50 border-b border-[var(--hairline)] bg-[var(--canvas)]/80 backdrop-blur-sm">
      <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-6">
        <div class="flex h-full items-center gap-8">
          <a href="/" class="flex items-center gap-2">
            <img src="/brand/bapx-logo-main.svg" alt="bapX" class="h-7 w-auto" />
          </a>
          <div class="bapx-nav hidden lg:flex h-full items-center gap-7">
            <a href="/" class="active">Home</a>
            <a href="https://docs.bapx.in/getting-started/quickstart/">Docs</a>
            <a href="/platform/">Platform</a>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <a href="https://agents.bapx.in/" class="bapx-pill">Agents</a>
          <a href="/login/" class="bapx-pill bapx-pill-primary">Sign in</a>
        </div>
      </div>
    </nav>

    <main>
      <!-- HERO -->
      <section class="page-section page-header">
        <div class="section-inner" style="max-width: 1200px;">
          <h1 class="display-xl" style="max-width: 14ch;">
            Agent automation for your team.
          </h1>
          <p class="body-lg" style="margin-top: 1.5rem; max-width: 560px;">
            Deploy AI agents that automate your business operations, team workflows, and customer support — all managed from the cloud, no infrastructure required.
          </p>
          <div class="hero-actions">
            <a href="https://platform.bapx.in/" class="bapx-pill bapx-pill-primary">Get started free</a>
            <a href="https://docs.bapx.in/getting-started/quickstart/" class="bapx-pill">Read the docs</a>
          </div>
        </div>
      </section>

      <!-- Why bapX -->
      <section class="page-section">
        <div class="section-inner">
          <div class="section-heading">
            <div>
              <h2 class="display-md">Agent automation, managed for you.</h2>
              <p class="body-lg" style="margin-top: 1.5rem;">
                bapX is a cloud platform for deploying AI agents that automate your business operations. Create agents from your browser, connect them to your tools, and collaborate with your team — no servers, no infrastructure.
              </p>
              <p class="body-lg" style="margin-top: 1.5rem;">
                Your agents run in our cloud with built-in scaling, monitoring, and team access. Connect any LLM provider, integrate with <a href="https://docs.bapx.in/guide/channels/" style="color: var(--ink); text-decoration: underline; text-decoration-color: var(--body-mid); text-underline-offset: 2px;">Slack, GitHub, email, and more</a>.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Platform features -->
      <section class="page-section">
        <div class="section-inner">
          <div class="section-heading compact">
            <h2 class="display-md">Everything your team needs.</h2>
            <p class="body-lg">
              Create, deploy, and manage agents as a team. bapX handles the infrastructure so you can focus on what your agents do.
            </p>
          </div>
          <div class="card-grid-3" style="margin-top: 2rem;">
            <div class="card">
              <span class="mono-label">Workspace</span>
              <p class="body-sm" style="margin-top: .75rem; color: var(--ink);">Create agents from your browser. No CLI, no DevOps, no setup.</p>
            </div>
            <div class="card">
              <span class="mono-label">Channels</span>
              <p class="body-sm" style="margin-top: .75rem; color: var(--ink);">Connect agents to Slack, GitHub, Linear, email, and more.</p>
            </div>
            <div class="card">
              <span class="mono-label">Teams</span>
              <p class="body-sm" style="margin-top: .75rem; color: var(--ink);">Invite your team, assign roles, share agents across your org.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Ecosystem -->
      <section class="page-section">
        <div class="section-inner">
          <div class="section-heading compact">
            <h2 class="display-md">Connect to the tools you already use.</h2>
            <p class="body-lg">
              bapX integrates with your team's workflow through channels, APIs, and managed integrations.
            </p>
            <a href="https://docs.bapx.in/ecosystem/" class="bapx-pill" style="margin-top: 1rem;">View all integrations</a>
          </div>
          <div class="client-grid">
            {homepageEcosystemItems.slice(0, 12).map((app) => (
              <a href={app.href} class="client-card" style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100px; padding: 1rem; text-align: center;">
                {app.icon ? (
                  <img src={app.icon} alt={app.name} style="max-height: 2.5rem; max-width: 80%; filter: brightness(0) invert(1); opacity: .6;" />
                ) : (
                  <span style="color: var(--body-mid); font-size: .875rem;">{app.name}</span>
                )}
              </a>
            ))}
            <a href="/docs/ecosystem/" class="client-card" style="display: flex; align-items: center; justify-content: center; min-height: 120px;">
              <span style="color: var(--body-mid); font-size: .875rem;">View all &rarr;</span>
            </a>
          </div>
        </div>
      </section>

      <!-- Features -->
      <section class="page-section">
        <div class="section-inner">
          <div class="section-heading compact">
            <h2 class="display-md">One platform for every team.</h2>
            <p class="body-lg">Deploy agents for customer support, engineering, operations, and sales — all from one workspace.</p>
          </div>
          <div class="card-grid-auto" style="margin-top: 3rem;">
            <a href="/docs/platform/overview/" class="card">
              <span class="mono-label">Managed</span>
              <h3 class="display-md" style="margin-top: .5rem;">Workspace</h3>
              <p class="body-sm" style="margin-top: .75rem;">Create and manage agents from your browser. No infrastructure to set up.</p>
            </a>
            <a href="/docs/guide/channels/" class="card">
              <span class="mono-label">Connect</span>
              <h3 class="display-md" style="margin-top: .5rem;">Channels</h3>
              <p class="body-sm" style="margin-top: .75rem;">Connect agents to Slack, GitHub, email, Discord, and more.</p>
            </a>
            <a href="/docs/platform/organisations/" class="card">
              <span class="mono-label">Team</span>
              <h3 class="display-md" style="margin-top: .5rem;">Organisations</h3>
              <p class="body-sm" style="margin-top: .75rem;">Invite your team, assign roles, and collaborate on agents.</p>
            </a>
            <a href="/docs/mcp/overview/" class="card">
              <span class="mono-label">MCP</span>
              <h3 class="display-md" style="margin-top: .5rem;">MCP Gateway</h3>
              <p class="body-sm" style="margin-top: .75rem;">Give agents access to external tools via the Model Context Protocol.</p>
            </a>
            <a href="/docs/platform/billing/" class="card">
              <span class="mono-label">Usage</span>
              <h3 class="display-md" style="margin-top: .5rem;">Billing & Scaling</h3>
              <p class="body-sm" style="margin-top: .75rem;">$5/mo per workspace. Scale as your team grows.</p>
            </a>
            <a href="/docs/guide/observability/" class="card">
              <span class="mono-label">Monitor</span>
              <h3 class="display-md" style="margin-top: .5rem;">Observability</h3>
              <p class="body-sm" style="margin-top: .75rem;">View agent activity, conversation logs, and usage from your dashboard.</p>
            </a>
            <a href="/docs/api/overview/" class="card">
              <span class="mono-label">API</span>
              <h3 class="display-md" style="margin-top: .5rem;">Platform API</h3>
              <p class="body-sm" style="margin-top: .75rem;">Programmatic access to your agents, workspaces, and billing.</p>
            </a>
            <a href="/docs/getting-started/quickstart/" class="card" style="display: flex; flex-direction: column; align-items: flex-start; justify-content: center; background: var(--canvas-mid);">
              <span class="mono-label" style="color: var(--body);">Get Started</span>
              <h3 class="display-md" style="margin-top: .5rem;">Sign up free <span style="display: inline-block; transition: transform .15s;">&rarr;</span></h3>
              <p class="body-sm" style="margin-top: .75rem;">Create your workspace and deploy your first agent in minutes.</p>
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer class="page-footer">
      <div class="section-inner">
      <span>bapX — Cloud Agent Automation for Teams.</span>
      <span>&copy; {new Date().getFullYear()}</span>
      </div>
    </footer>
  </body>
</html>
