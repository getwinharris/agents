---
import "../styles/global.css";
import { Code } from "astro:components";
import { HERO, COPY_PROMPT } from "../code-snippets";
import { ecosystemPublicHref, homepageEcosystemItems } from "../../../ecosystem-catalog";

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=bapx-20260711" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <title>bapX — Marketing operations, built into agents</title>
    <meta name="description" content="Put 10+ years of marketing and branding operations to work through hosted agents. ₹500/month includes 5 GB storage, hosting, hosted search, browser sessions, Node.js project subdomains, TTS, and STT." />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href="https://bapx.in/" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="bapX" />
    <meta property="og:title" content="bapX — Marketing operations, built into agents" />
    <meta property="og:description" content="Put 10+ years of marketing and branding operations to work through hosted agents." />
    <meta property="og:url" content="https://bapx.in/" />
    <meta property="og:image" content="https://bapx.in/og3.jpg" />
    <meta property="og:image:alt" content="bapX logo" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="bapX — Marketing operations, built into agents" />
    <meta name="twitter:description" content="Put 10+ years of marketing and branding operations to work through hosted agents." />
    <meta name="twitter:image" content="https://bapx.in/og3.jpg" />
    <meta name="twitter:image:alt" content="bapX logo" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="sticky top-0 z-50 border-b border-[var(--hairline)] bg-[var(--canvas)]/80 backdrop-blur-sm">
      <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-6">
        <div class="flex h-full items-center gap-8">
          <a href="/" class="flex items-center gap-2">
            <img src="/brand/bapx-logo-main.svg" alt="bapX" class="h-7 w-auto" />
          </a>
          <div class="bapx-nav hidden lg:flex h-full items-center gap-7">
            <a href="/" class="active">Home</a>
            <a href="https://docs.bapx.in/getting-started/quickstart/">Docs</a>
            <a href="https://blogs.bapx.in/">Blogs</a>
            <a href="https://mediahub.bapx.in/">Media Hub</a>
            <a href="https://platform.bapx.in/">Platform</a>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <a href="https://agents.bapx.in/" class="bapx-pill landing-desktop-action">Agents</a>
          <a href="/login/" class="bapx-pill bapx-pill-primary">Sign in</a>
          <button class="landing-menu-toggle" type="button" aria-label="Open navigation menu" aria-expanded="false" aria-controls="landing-mobile-menu">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
          </button>
        </div>
      </div>
      <div id="landing-mobile-menu" class="landing-mobile-menu" hidden>
        <a href="/" class="active">Home</a>
        <a href="https://docs.bapx.in/getting-started/quickstart/">Docs</a>
        <a href="https://blogs.bapx.in/">Blogs</a>
        <a href="https://mediahub.bapx.in/">Media Hub</a>
        <a href="https://platform.bapx.in/">Platform</a>
        <a href="https://agents.bapx.in/">Agents</a>
      </div>
    </nav>

    <main>
      <!-- HERO -->
      <section class="page-section page-header">
        <div class="section-inner" style="max-width: 1200px;">
          <h1 class="display-xl" style="max-width: 14ch;">
            Our marketing team, built into your agents.
          </h1>
          <p class="body-lg" style="margin-top: 1.5rem; max-width: 560px;">
            Put 10+ years of marketing and branding operations to work in your business. bapX turns proven agency workflows into hosted agents your team can direct, observe, and improve.
          </p>
          <div class="hero-actions">
            <a href="https://platform.bapx.in/" class="bapx-pill bapx-pill-primary">Get started — ₹500/month</a>
            <a href="https://docs.bapx.in/getting-started/quickstart/" class="bapx-pill">Read the docs</a>
          </div>
        </div>
      </section>

      <!-- Why bapX -->
      <section class="page-section">
        <div class="section-inner">
          <div class="section-heading">
            <div>
              <h2 class="display-md">Agency operations, ready to deploy.</h2>
              <p class="body-lg" style="margin-top: 1.5rem;">
                bapX is the operating knowledge of a marketing and branding agency, packaged as agents. Build campaign, brand, content, media, reporting, and product workflows around the way your business already works.
              </p>
              <p class="body-lg" style="margin-top: 1.5rem;">
                Agents are hosted for you and organised under your account, businesses, and projects. Bring your AI-provider keys and connector credentials, or import an existing GitHub project without leaving the bapX OKF workspace structure.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Platform features -->
      <section class="page-section">
        <div class="section-inner">
          <div class="section-heading compact">
            <h2 class="display-md">Your business stays in control.</h2>
            <p class="body-lg">
              Each account has its own OKF workspace. Every business, project, agent, automation, asset, and connection has a defined place that your people can manage together.
            </p>
          </div>
          <div class="card-grid-3" style="margin-top: 2rem;">
            <div class="card">
              <span class="mono-label">Business workspace</span>
              <p class="body-sm" style="margin-top: .75rem; color: var(--ink);">Manage businesses, projects, people, brand assets, documents, and agent work from one structured workspace.</p>
            </div>
            <div class="card">
              <span class="mono-label">Bring your tools</span>
              <p class="body-sm" style="margin-top: .75rem; color: var(--ink);">Connect your AI providers, MCP servers, APIs, social channels, GitHub repositories, and business tools.</p>
            </div>
            <div class="card">
              <span class="mono-label">People and agents</span>
              <p class="body-sm" style="margin-top: .75rem; color: var(--ink);">Invite people, assign responsibilities, and coordinate role-specific agents across each business and project.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Ecosystem -->
      <section class="page-section">
        <div class="section-inner">
          <div class="section-heading compact">
            <h2 class="display-md">Connect to the tools you already use.</h2>
            <p class="body-lg">
              bapX integrates with your team's workflow through channels, APIs, and managed integrations.
            </p>
            <a href="https://docs.bapx.in/ecosystem/" class="bapx-pill" style="margin-top: 1rem;">View all integrations</a>
          </div>
          <div class="client-grid">
            {homepageEcosystemItems.slice(0, 12).map((app) => (
              <a href={ecosystemPublicHref(app)} class="client-card" style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100px; padding: 1rem; text-align: center;">
                {app.icon ? (
                  <img src={app.icon} alt={app.name} style="max-height: 2.5rem; max-width: 80%; filter: brightness(0) invert(1); opacity: .6;" />
                ) : (
                  <span style="color: var(--body-mid); font-size: .875rem;">{app.name}</span>
                )}
              </a>
            ))}
            <a href="https://docs.bapx.in/ecosystem/" class="client-card" style="display: flex; align-items: center; justify-content: center; min-height: 120px;">
              <span style="color: var(--body-mid); font-size: .875rem;">View all &rarr;</span>
            </a>
          </div>
        </div>
      </section>

      <!-- Features -->
      <section class="page-section">
        <div class="section-inner">
          <div class="section-heading compact">
            <h2 class="display-md">India-first billing for storage and hosted work.</h2>
            <p class="body-lg">₹500/month includes 5 GB storage, hosted agents and workflows, hosted search, browser sessions, Node.js project subdomains, TTS, and STT. Scale to 100 GB at ₹100/GB/month. Bring your own AI tokens and connector credentials.</p>
          </div>
          <div class="card-grid-auto" style="margin-top: 3rem;">
            <a href="/docs/platform/overview/" class="card">
              <span class="mono-label">Managed</span>
              <h3 class="display-md" style="margin-top: .5rem;">Workspace</h3>
              <p class="body-sm" style="margin-top: .75rem;">Create and manage agents from your browser. No infrastructure to set up.</p>
            </a>
            <a href="/docs/guide/channels/" class="card">
              <span class="mono-label">Connect</span>
              <h3 class="display-md" style="margin-top: .5rem;">Channels</h3>
              <p class="body-sm" style="margin-top: .75rem;">Connect agents to Slack, GitHub, email, Discord, and more.</p>
            </a>
            <a href="/docs/platform/organisations/" class="card">
              <span class="mono-label">Team</span>
              <h3 class="display-md" style="margin-top: .5rem;">Organisations</h3>
              <p class="body-sm" style="margin-top: .75rem;">Invite your team, assign roles, and collaborate on agents.</p>
            </a>
            <a href="/docs/mcp/overview/" class="card">
              <span class="mono-label">MCP</span>
              <h3 class="display-md" style="margin-top: .5rem;">MCP Gateway</h3>
              <p class="body-sm" style="margin-top: .75rem;">Give agents access to external tools via the Model Context Protocol.</p>
            </a>
            <a href="/docs/platform/billing/" class="card">
              <span class="mono-label">Usage</span>
              <h3 class="display-md" style="margin-top: .5rem;">Billing & Limits</h3>
              <p class="body-sm" style="margin-top: .75rem;">₹500/mo includes 5 GB. Add storage at ₹100/GB/month up to 100 GB.</p>
            </a>
            <a href="/docs/guide/observability/" class="card">
              <span class="mono-label">Monitor</span>
              <h3 class="display-md" style="margin-top: .5rem;">Observability</h3>
              <p class="body-sm" style="margin-top: .75rem;">View agent activity, conversation logs, and usage from your dashboard.</p>
            </a>
            <a href="/docs/api/agent-api/" class="card">
              <span class="mono-label">API</span>
              <h3 class="display-md" style="margin-top: .5rem;">Platform API</h3>
              <p class="body-sm" style="margin-top: .75rem;">Programmatic access to your agents, workspaces, and billing.</p>
            </a>
            <a href="/docs/getting-started/quickstart/" class="card" style="display: flex; flex-direction: column; align-items: flex-start; justify-content: center; background: var(--canvas-mid);">
              <span class="mono-label" style="color: var(--body);">Get Started</span>
              <h3 class="display-md" style="margin-top: .5rem;">Start for ₹500/month <span style="display: inline-block; transition: transform .15s;">&rarr;</span></h3>
              <p class="body-sm" style="margin-top: .75rem;">Create your account, business workspace, and first project with 5 GB included.</p>
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer class="page-footer">
      <div class="section-inner">
      <span>bapX — Marketing operations, built into agents.</span>
      <span>&copy; {new Date().getFullYear()}</span>
      </div>
    </footer>
    <script is:inline>
      const menuToggle = document.querySelector('.landing-menu-toggle');
      const mobileMenu = document.querySelector('#landing-mobile-menu');
      const setMenuOpen = (open) => {
        mobileMenu.hidden = !open;
        menuToggle.setAttribute('aria-expanded', String(open));
        menuToggle.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
      };
      menuToggle.addEventListener('click', () => setMenuOpen(menuToggle.getAttribute('aria-expanded') !== 'true'));
      mobileMenu.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => setMenuOpen(false)));
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          setMenuOpen(false);
          menuToggle.focus();
        }
      });
    </script>
  </body>
</html>
