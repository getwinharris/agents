---
import "../../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign In | bapX</title>
    <meta name="description" content="Sign in to bapX to manage your account, billing, and agents." />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="sticky top-0 z-50 border-b border-[var(--hairline)] bg-[var(--canvas)]/80 backdrop-blur-sm">
      <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-6">
        <div class="flex h-full items-center gap-8">
          <a href="/" class="flex items-center gap-2">
            <img src="/brand/bapx-logo-main.svg" alt="bapX" class="h-7 w-auto" />
          </a>
          <div class="bapx-nav hidden lg:flex h-full items-center gap-7">
            <a href="/">Home</a>
            <a href="https://docs.bapx.in/getting-started/quickstart/">Docs</a>
            <a href="/blog/">Blog</a>
            <a href="/platform/">Platform</a>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <a href="/login/" class="bapx-pill">Sign in</a>
          <a href="/login/?signup=1" class="bapx-pill bapx-pill-primary">Sign up</a>
        </div>
      </div>
    </nav>

    <main>
      <section class="page-section page-header">
        <div class="section-inner" style="max-width: 440px;">
          <div id="auth-form" data-mode="login">
            <div id="login-form">
              <span class="mono-label">bapX</span>
              <h1 class="display-md" style="margin-top: 1rem;">Sign in</h1>
              <p class="body-sm" style="margin-top: .75rem; color: var(--body-mid);">Enter your email to sign in or create an account.</p>
              <form action="/api/auth/login" method="POST" style="margin-top: 2rem; display: grid; gap: 1rem;">
                <div>
                  <label style="display: block; color: var(--body-mid); font-size: .875rem; margin-bottom: .375rem;">Email</label>
                  <input name="email" type="email" required placeholder="you@example.com" style="width: 100%; padding: .625rem .75rem; border: 1px solid var(--hairline); border-radius: 6px; background: var(--canvas-card); color: var(--ink); font-size: .875rem;" />
                </div>
                <button type="submit" class="bapx-pill bapx-pill-primary" style="cursor: pointer; border: none; font-family: inherit; justify-content: center;">Continue with email</button>
              </form>
              <div style="margin-top: 1.5rem; text-align: center;">
                <p class="body-sm" style="color: var(--body-mid);">Don't have an account? <a href="/login/?signup=1" class="mono-label" style="display: inline; color: var(--ink); cursor: pointer;">Sign up</a></p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="page-footer">
      <div class="section-inner">
        <span>bapX — the open agent harness.</span>
        <span>&copy; {new Date().getFullYear()}</span>
      </div>
    </footer>

    <script>
      const params = new URLSearchParams(window.location.search);
      if (params.get('signup') === '1') {
        document.title = 'Sign Up | bapX';
        document.querySelector('.mono-label').textContent = 'bapX';
        document.querySelector('.display-md').textContent = 'Create account';
        document.querySelector('.body-sm').textContent = 'Enter your email to create your bapX account.';
        document.querySelector('button[type="submit"]').textContent = 'Create account';
        document.querySelector('[href*="signup"').textContent = 'Sign in';
        document.querySelector('[href*="signup"').href = '/login/';
      }
    </script>
  </body>
</html>