---
import '../../styles/global.css';
---
<!doctype html><html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><title>Sign in | bapX</title><link rel="icon" type="image/svg+xml" href="/favicon.svg?v=bapx-20260711"/></head>
<body class="auth-page"><main class="auth-card"><a href="https://bapx.in/" class="auth-brand"><img src="/brand/bapx-logo-main.svg" alt="bapX"/></a><p class="mono-label">WELCOME BACK</p><h1>Sign in to your business workspace.</h1><p id="error" class="auth-error"></p>
<form action="/api/auth/login" method="post"><label>Username or email<input name="identity" autocomplete="username" required/></label><label>Password<input type="password" name="password" autocomplete="current-password" required/></label><button class="bapx-pill bapx-pill-primary" type="submit">Sign in</button></form>
<div class="auth-divider">or continue with</div><div class="auth-providers"><a class="bapx-pill" href="/api/auth/oauth/google">Google</a><a class="bapx-pill" href="/api/auth/oauth/github">GitHub</a></div>
<p class="auth-foot">New to bapX? <a href="https://bapx.in/signup/">Create an account</a></p></main>
<script is:inline>document.querySelector('#error').textContent=new URLSearchParams(location.search).get('error')||'';</script></body></html>
<style>
.auth-page{min-height:100vh;display:grid;place-items:center;background:#0a0a0a;color:#fff;padding:24px}.auth-card{width:min(460px,100%);border:1px solid var(--hairline);border-radius:8px;padding:32px;background:#191919}.auth-brand{font-size:24px}.mono-label{margin-top:42px}.auth-card h1{font-size:40px;line-height:1.05;font-weight:400;letter-spacing:-.04em;margin:12px 0 28px}.auth-card form{display:grid;gap:18px}.auth-card label{display:grid;gap:8px;color:#dadbdf;font-size:14px}.auth-card input{background:#1a1c20;border:1px solid #363a3f;border-radius:8px;padding:14px;color:#fff;font:inherit}.auth-divider{text-align:center;color:#7d8187;margin:24px 0}.auth-providers{display:grid;grid-template-columns:1fr 1fr;gap:12px}.auth-providers a{text-align:center}.auth-foot{text-align:center;margin-top:28px;color:#dadbdf}.auth-error{color:#ffb4a8;min-height:20px}
.auth-brand img{display:block;width:112px;height:auto}
</style>
