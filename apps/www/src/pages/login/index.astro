---
import '../../styles/global.css';
---
<!doctype html><html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><title>Sign in | bapX</title><link rel="icon" type="image/svg+xml" href="/favicon.svg?v=bapx-20260711"/></head><body class="auth-page"><main class="auth-card"><a href="https://bapx.in/" class="auth-brand"><img src="/brand/bapx-logo-main.svg" alt="bapX"/></a><p class="mono-label">WELCOME BACK</p><h1>Sign in with GitHub.</h1><p>GitHub is the identity for your bapX account and business workspaces.</p><p id="error" class="auth-error"></p><a class="bapx-pill bapx-pill-primary github-auth" href="/api/auth/oauth/github">Continue with GitHub</a><p class="auth-foot">New to bapX? <a href="https://bapx.in/signup/">Create your account</a></p></main><script is:inline>document.querySelector('#error').textContent=new URLSearchParams(location.search).get('error')||'';</script></body></html>
<style>.auth-page{min-height:100vh;display:grid;place-items:center;background:#0a0a0a;color:#fff;padding:24px}.auth-card{width:min(460px,100%);border:1px solid var(--hairline);border-radius:8px;padding:32px;background:#191919}.auth-brand img{display:block;width:112px}.mono-label{margin-top:42px}.auth-card h1{font-size:40px;font-weight:400;letter-spacing:-.04em;margin:12px 0 20px}.auth-card>p{color:#a9abb1;line-height:1.6}.github-auth{display:flex;justify-content:center;margin-top:28px}.auth-foot{text-align:center;margin-top:28px}.auth-error{color:#ffb4a8;min-height:20px}</style>
