---
import "../../styles/global.css";

const posts = [
  {
    title: "bapX 1.0 Beta",
    slug: "/blog/bapX-1-0-beta/",
    date: "2026-06-15",
    excerpt: "The bapX agent harness enters public beta. Build durable AI agents with TypeScript, deploy anywhere.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blog | bapX</title>
    <meta name="description" content="bapX blog — agent harness, AI workflows, and ecosystem updates." />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href="https://bapx.in/blog/" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="sticky top-0 z-50 border-b border-[var(--hairline)] bg-[var(--canvas)]/80 backdrop-blur-sm">
      <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-6">
        <div class="flex h-full items-center gap-8">
          <a href="/" class="flex items-center gap-2">
            <img src="/brand/bapx-logo-main.svg" alt="bapX" class="h-7 w-auto" />
          </a>
          <div class="bapx-nav hidden lg:flex h-full items-center gap-7">
            <a href="/">Home</a>
            <a href="https://docs.bapx.in/getting-started/quickstart/">Docs</a>
            <a href="/blog/" class="active">Blog</a>
            <a href="/platform/">Platform</a>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <a href="https://agents.bapx.in/" class="bapx-pill">Agents</a>
          <a href="/login/" class="bapx-pill bapx-pill-primary">Sign in</a>
        </div>
      </div>
    </nav>

    <main class="page-section page-header">
      <div class="section-inner" style="max-width: 720px;">
        <span class="mono-label">Blog</span>
        <h1 class="display-xl" style="margin-top: 1.75rem;">Blog</h1>
        <p class="body-lg" style="margin-top: 1.5rem; max-width: 560px;">Updates, announcements, and deep dives from the bapX team.</p>

        <div class="blog-list">
          {posts.map((post) => (
            <article class="card blog-card">
              <span class="mono-label">{new Date(post.date + "T00:00:00Z").toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric", timeZone: "UTC" })}</span>
              <h2 class="display-md"><a href={post.slug} style="transition:color .15s;">{post.title}</a></h2>
              <p class="body-sm">{post.excerpt}</p>
              <a href={post.slug} class="bapx-pill">Read more</a>
            </article>
          ))}
        </div>
      </div>
    </main>

    <footer class="page-footer">
      <div class="section-inner">
        <span>bapX — the open agent harness.</span>
        <span>&copy; {new Date().getFullYear()}</span>
      </div>
    </footer>
  </body>
</html>
