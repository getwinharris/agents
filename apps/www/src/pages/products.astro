---
import "../styles/global.css";

const navItems = [
  ["Home", "https://bapx.in/"],
  ["Products", "/products/"],
  ["Pricing", "/pricing/"],
  ["Docs", "https://docs.bapx.in/"],
  ["Research", "https://blogs.bapx.in/research/"],
  ["Releases", "https://blogs.bapx.in/release/"],
  ["Media Hub", "https://mediahub.bapx.in/"],
] as const;

const productCards = [
  ["bapX Agent", "The central agent that coordinates specialist agents, people, threads, PRs, automations, browser checks, and project context.", "https://agents.bapx.in/", "Open Agents"],
  ["Platform", "Account, business, members, projects, storage, billing, API keys, connectors, MCP configuration, and observability.", "https://platform.bapx.in/", "Open Platform"],
  ["Admin", "The same operating surface with bapX-wide authority for managing bapx.in workspace operations, users, projects, and releases.", "https://admin.bapx.in/", "Open Admin"],
  ["MCP / A2A Gateway", "Tool access through the MCP gateway and agent-to-agent handoffs for coordinating specialist workers safely.", "https://docs.bapx.in/mcp/overview/", "MCP docs"],
  ["Channels & connectors", "GitHub, Slack, Linear, Sentry, Razorpay, webhooks, browser sessions, hosted search, and external MCPs as product connectors.", "https://docs.bapx.in/ecosystem/", "Ecosystem"],
  ["bapX Host + bapXdb", "Node.js project subdomains, hosted search/browser work, and OKF YAML/JSON data storage under each project workspace.", "https://docs.bapx.in/ecosystem/deploy/bapx-host/", "Hosting docs"],
] as const;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Products | bapX</title>
    <meta name="description" content="bapX products — hosted agent operations, Platform, MCP, API, connectors, and business workspaces." />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href="https://bapx.in/products/" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=bapx-20260711" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="sticky top-0 z-50 border-b border-[var(--hairline)] bg-[var(--canvas)]/80 backdrop-blur-sm">
      <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-6">
        <div class="flex h-full items-center gap-8">
          <a href="/" class="flex items-center gap-2">
            <img src="/brand/bapx-logo-main.svg" alt="bapX" class="h-7 w-auto" />
          </a>
          <div class="bapx-nav hidden lg:flex h-full items-center gap-7">
            {navItems.map(([label, href]) => (
              <a href={href} class={label === "Products" ? "active" : undefined}>{label}</a>
            ))}
          </div>
        </div>
        <div class="flex items-center gap-3">
          <a href="https://agents.bapx.in/" class="bapx-pill">Agents</a>
          <a href="/login/" class="bapx-pill bapx-pill-primary">Sign in</a>
        </div>
      </div>
    </nav>

    <main class="page-section page-header">
      <div class="section-inner">
        <span class="mono-label">Products</span>
        <h1 class="display-xl" style="margin-top: 1.75rem; max-width: 12ch;">One workspace for people and agents.</h1>
        <p class="body-lg" style="margin-top: 1.5rem; max-width: 760px;">bapX is the operating layer for businesses that want hosted agents, governed developer tools, channels, MCP/A2A access, project hosting, data, storage, billing, and observability in one place.</p>

        <div class="card-grid-auto" style="margin-top: 3.375rem;">
          {productCards.map(([title, body, href, cta]) => (
            <article class="card">
              <span class="mono-label">{title}</span>
              <p class="body-sm" style="margin-top: 1.25rem; color: var(--ink);">{body}</p>
              <a href={href} class="bapx-pill" style="margin-top: 1.125rem;">{cta}</a>
            </article>
          ))}
        </div>
      </div>
    </main>

    <footer class="page-footer">
      <div class="section-inner">
        <span>bapX — Marketing operations, built into agents.</span>
        <span>&copy; {new Date().getFullYear()}</span>
      </div>
    </footer>
  </body>
</html>
