---
import "../styles/global.css";
import BlogCover from "../components/BlogCover.astro";

interface Frontmatter {
	title: string;
	subtitle?: string;
	description?: string;
	author?: string;
	authorUrl?: string;
	pubDate?: string;
}

const { frontmatter } = Astro.props as { frontmatter: Frontmatter };
const { title, subtitle, description, author, authorUrl, pubDate } = frontmatter;

const pageTitle = `${title} | bapX`;
const pageDescription = description ?? subtitle ?? "The open framework for building durable agents.";
const canonicalUrl = new URL(Astro.url.pathname, "https://bapx.in").href;
const formattedDate = pubDate
	? new Date(`${pubDate}T00:00:00Z`).toLocaleDateString("en-US", {
			month: "long",
			day: "numeric",
			year: "numeric",
			timeZone: "UTC",
		})
	: undefined;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={pageDescription} />
		<meta name="theme-color" content="#0a0a0a" />
		<link rel="canonical" href={canonicalUrl} />

		<meta property="og:type" content="article" />
		<meta property="og:site_name" content="bapX" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content="https://bapx.in/og4.jpg" />
		<meta property="og:image:alt" content="bapX logo" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content="https://bapx.in/og4.jpg" />
		<meta name="twitter:image:alt" content="bapX logo" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
	</head>
	<body>
		<nav class="sticky top-0 z-50 border-b border-[var(--hairline)] bg-[var(--canvas)]/80 backdrop-blur-sm">
			<div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-6">
				<div class="flex h-full items-center gap-8">
					<a href="/" class="flex items-center gap-2">
						<img src="/brand/bapx-logo-main.svg" alt="bapX" class="h-7 w-auto" />
					</a>
					<div class="bapx-nav hidden h-full items-center gap-7 lg:flex">
						<a href="/">Home</a>
						<a href="https://docs.bapx.in/getting-started/quickstart/">Docs</a>
						<a href="/mediahub/">Media Hub</a>
						<a href="/blog/" class="active">Blog</a>
						<a href="/products/">Products</a>
						<a href="/contact/">Contact</a>
					</div>
				</div>
				<div class="flex items-center gap-3">
					<a href="https://agents.bapx.in/" class="bapx-pill">Agents</a>
					<a href="/login/" class="bapx-pill bapx-pill-primary">Sign in</a>
				</div>
			</div>
		</nav>

		<main class="mx-auto w-[min(100%,46rem)] px-5 pb-24 pt-8 sm:pt-10" style="margin-top: 2rem;">
			<header class="mb-8 border-b border-[var(--hairline)] pb-5">
				<BlogCover />
				<h1 class="display-lg" style="margin-top: .5rem;">{title}</h1>
				<div class="mt-1 flex flex-wrap items-center gap-x-2 text-sm" style="color: var(--body-mid);">
					{author && (
						<span>
							By{" "}
							{authorUrl
								? <a href={authorUrl} target="_blank" rel="noopener noreferrer" style="color: var(--body); transition: color .15s;">{author}</a>
								: <span style="color: var(--body);">{author}</span>
							}
						</span>
					)}
					{author && formattedDate && <span aria-hidden="true">·</span>}
					{formattedDate && <time datetime={pubDate}>{formattedDate}</time>}
				</div>
			</header>

			<article class="blog-content">
				<slot />
			</article>
		</main>

		<footer class="page-footer">
			<div class="section-inner">
				<span>bapX — the open agent harness.</span>
				<span>&copy; {new Date().getFullYear()}</span>
			</div>
		</footer>

		<script is:inline>
			for (const heading of document.querySelectorAll(".blog-content :is(h2, h3, h4)[id]")) {
				const anchor = document.createElement("a");
				anchor.className = "blog-heading-anchor";
				anchor.href = `#${heading.id}`;
				anchor.setAttribute("aria-label", `Link to ${heading.textContent ?? "section"}`);
				anchor.textContent = "#";
				heading.append(anchor);
			}
		</script>
	</body>
</html>
