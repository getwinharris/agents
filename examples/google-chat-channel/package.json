{
	"name": "google-chat-channel-example",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "bapX build --target node",
		"check:types": "tsc --noEmit",
		"test": "npm run test:node && npm run test:workerd",
		"test:node": "vitest run test/client.test.ts test/conversation.test.ts",
		"test:workerd": "vitest run --config vitest.workerd.config.ts"
	},
	"dependencies": {
		"@bapX/google-chat": "*",
		"@bapX/runtime": "*",
		"jose": "*",
		"valibot": "^1.0.0"
	},
	"devDependencies": {
		"@bapX/cli": "*",
		"@cloudflare/vitest-pool-workers": "0.16.20",
		"agents": "^0.14.2",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
	}
}
