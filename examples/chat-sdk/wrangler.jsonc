{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "chat-sdk-example",
	"compatibility_date": "2026-06-01",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"migrations": [
		{
			"tag": "bapX-class-Assistant",
			"new_sqlite_classes": [
				"Assistant"
			]
		},
		{
			"tag": "bapX-class-BapxRegistry",
			"new_sqlite_classes": [
				"BapxRegistry"
			]
		},
		{
			"tag": "bapX-rename-generated-classes",
			"renamed_classes": [
				{
					"from": "Assistant",
					"to": "BapxAssistantAgent"
				}
			]
		}
	]
}
